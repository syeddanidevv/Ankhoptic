generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model AdminUser {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String
  password  String
  role      AdminRole @default(STAFF)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("admin_users")
}

model Customer {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  phone         String?
  password      String?
  emailVerified DateTime?
  totalSpent    Float     @default(0)
  ordersCount   Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  addresses     Address[]
  cart          Cart?
  orders        Order[]
  reviews       Review[]

  @@map("customers")
}

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  image     String?    @db.Text
  position  Int        @default(0)
  parentId  String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  brandId   String?
  brand     Brand?     @relation(fields: [brandId], references: [id])
  parent    Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryChildren")
  products  Product[]
  discounts Discount[] @relation("categorydiscounts")

  @@index([brandId], map: "categories_brandId_fkey")
  @@index([parentId], map: "categories_parentId_fkey")
  @@map("categories")
}

model Brand {
  id         String     @id @default(cuid())
  name       String
  slug       String     @unique
  logo       String?    @db.Text
  createdAt  DateTime   @default(now())
  categories Category[]
  products   Product[]
  discounts  Discount[] @relation("branddiscounts")

  @@map("brands")
}

model Product {
  id              String               @id @default(cuid())
  title           String
  slug            String               @unique
  description     String?              @db.Text
  price           Float
  comparePrice    Float?
  discountPercent Float                @default(0)
  color           String?
  inStock         Boolean              @default(true)
  stockCount      Int                  @default(0)
  images          String               @db.LongText
  status          ProductStatus        @default(DRAFT)
  featured        Boolean              @default(false)
  brandId         String?
  categoryId      String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  disposability   String               @default("ONE_DAY")
  productType     ProductType
  enableAddons    Boolean              @default(true)
  cartItems       CartItem[]
  orderItems      OrderItem[]
  powerOptions    ProductPowerOption[]
  brand           Brand?               @relation(fields: [brandId], references: [id])
  category        Category?            @relation(fields: [categoryId], references: [id])
  reviews         Review[]
  discounts       Discount[]           @relation("productdiscounts")

  @@index([brandId], map: "products_brandId_fkey")
  @@index([categoryId], map: "products_categoryId_fkey")
  @@map("products")
}

model ProductPowerOption {
  id        String  @id @default(cuid())
  productId String
  value     String
  label     String
  position  Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId], map: "product_power_options_productId_fkey")
  @@map("product_power_options")
}

model AftercareAddon {
  id          String      @id @default(cuid())
  name        String
  extraCharge Float
  retailPrice Float
  description String?
  image       String?     @db.LongText
  position    Int         @default(0)
  active      Boolean     @default(true)
  appliesTo   ProductType @default(LENS)

  @@map("aftercare_addons")
}

model Discount {
  id             String       @id @default(cuid())
  code           String?      @unique
  title          String
  type           DiscountType
  value          Float
  minOrderAmount Float?
  maxUsage       Int?
  usedCount      Int          @default(0)
  perCustomerMax Int?
  startsAt       DateTime?
  endsAt         DateTime?
  active         Boolean      @default(true)
  appliesToAll   Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  isAutomatic    Boolean      @default(false)
  orders         Order[]
  brands         Brand[]      @relation("branddiscounts")
  categories     Category[]   @relation("categorydiscounts")
  products       Product[]    @relation("productdiscounts")

  @@map("discounts")
}

model Order {
  id                String        @id @default(cuid())
  orderNumber       Int           @unique @default(autoincrement())
  customerId        String?
  status            OrderStatus   @default(PENDING)
  paymentStatus     PaymentStatus @default(UNPAID)
  paymentMethod     PaymentMethod @default(COD)
  fulfillmentStatus FulfillStatus @default(UNFULFILLED)
  subtotal          Float
  shippingCost      Float         @default(0)
  discountAmount    Float         @default(0)
  total             Float
  discountId        String?
  discountCode      String?
  shippingAddress   String        @db.LongText
  notes             String?       @db.Text
  trackingNumber    String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  items             OrderItem[]
  customer          Customer?     @relation(fields: [customerId], references: [id])
  discount          Discount?     @relation(fields: [discountId], references: [id])

  @@index([customerId], map: "orders_customerId_fkey")
  @@index([discountId], map: "orders_discountId_fkey")
  @@map("orders")
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  productId       String?
  productTitle    String
  productImage    String?
  lensType        LensType @default(PLAIN)
  rightEyePower   String?
  leftEyePower    String?
  prescriptionUrl String?
  aftercareName   String?
  aftercarePrice  Float    @default(0)
  qty             Int      @default(1)
  unitPrice       Float
  total           Float
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product? @relation(fields: [productId], references: [id])

  @@index([orderId], map: "order_items_orderId_fkey")
  @@index([productId], map: "order_items_productId_fkey")
  @@map("order_items")
}

model Cart {
  id         String     @id @default(cuid())
  customerId String?    @unique
  sessionId  String?    @unique
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  items      CartItem[]
  customer   Customer?  @relation(fields: [customerId], references: [id])

  @@map("carts")
}

model CartItem {
  id             String   @id @default(cuid())
  cartId         String
  productId      String
  lensType       LensType @default(PLAIN)
  rightEyePower  String?
  leftEyePower   String?
  aftercareName  String?
  aftercarePrice Float    @default(0)
  qty            Int      @default(1)
  createdAt      DateTime @default(now())
  cart           Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product        Product  @relation(fields: [productId], references: [id])

  @@index([cartId], map: "cart_items_cartId_fkey")
  @@index([productId], map: "cart_items_productId_fkey")
  @@map("cart_items")
}

model Address {
  id         String   @id @default(cuid())
  customerId String
  name       String
  phone      String
  line1      String
  line2      String?
  city       String
  province   String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id])

  @@index([customerId], map: "addresses_customerId_fkey")
  @@map("addresses")
}

model Review {
  id           String    @id @default(cuid())
  productId    String
  customerId   String?
  name         String
  rating       Int
  approved     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  customerMeta String?
  heading      String?
  image        String?   @db.LongText
  text         String?   @db.Text
  isFeatured   Boolean   @default(false)
  customer     Customer? @relation(fields: [customerId], references: [id])
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([customerId], map: "reviews_customerId_fkey")
  @@index([productId], map: "reviews_productId_fkey")
  @@map("reviews")
}

model StoreSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  @@map("store_settings")
}

model Testimonial {
  id          String   @id @default(cuid())
  rating      Int      @default(5)
  heading     String
  text        String   @db.Text
  authorName  String
  authorMeta  String?
  image       String?  @db.LongText
  productName String?
  productLink String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("testimonials")
}

enum AdminRole {
  OWNER
  ADMIN
  STAFF
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum ProductType {
  LENS
  GLASSES
  ACCESSORY
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PAID
  PARTIALLY_PAID
  REFUNDED
  COD_PENDING
  CANCELLED
}

enum PaymentMethod {
  COD
  EASYPAISA
  JAZZCASH
  CARD
  BANK_TRANSFER
}

enum FulfillStatus {
  UNFULFILLED
  PARTIALLY_FULFILLED
  FULFILLED
  SHIPPED
  RETURNED
  RESTOCKED
  CANCELLED
}

enum LensType {
  PLAIN
  EYESIGHT
}
